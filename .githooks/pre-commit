set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

python3 scripts/update_recipe_table.py

if ! git diff --quiet -- README.md; then
  echo "README.md recipe table was updated by scripts/update_recipe_table.py." >&2
  echo "Stage README.md and retry the commit." >&2
  exit 1
fi
